# Copie para .env e preencha com seus valores.
# Nunca commite o arquivo .env (ele está no .gitignore).

# Supabase PostgreSQL (use a connection string do painel Supabase)
# Para serverless (Vercel), prefira a URI com Connection pooling (porta 6543).
DATABASE_URL=postgresql://postgres:SENHA@db.SEUPROJETO.supabase.co:5432/postgres

# Produção (Vercel): defina no dashboard do projeto.
# SECRET_KEY=sua-chave-secreta-django
# DEBUG=0
# ALLOWED_HOSTS=.vercel.app,.now.sh
# PYTHONPATH=venv
