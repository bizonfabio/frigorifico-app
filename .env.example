# Copie este arquivo para .env local.
# NUNCA commite o .env (já está no .gitignore).

# Django
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,.now.sh

# CSRF (principalmente para produção/Vercel)
# Exemplo: https://frigorifico-app.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://frigorifico-app.vercel.app

# Banco (Supabase PostgreSQL)
# Prefira o pooler (porta 6543) para ambiente serverless.
# Se a senha tiver caracteres especiais, use URL-encode:
# @ -> %40 | , -> %2C | # -> %23 | / -> %2F
DATABASE_URL=postgresql://USUARIO:SENHA_URLENCODED@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Exemplo com senha C@lorado1,, codificada:
# DATABASE_URL=postgresql://USUARIO:C%40lorado1%2C%2C@aws-1-us-east-1.pooler.supabase.com:6543/postgres
